{
  "name": "packmind",
  "version": "1.0.1",
  "description": "Resume rate-limited Claude Code sessions and share a committed project memory Claude reads automatically.",
  "type": "module",
  "bin": {
    "packmind": "./dist/bin/packmind.js"
  },
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true})\"",
    "build": "tsc && tsc -p tsconfig.hooks.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:badge": "node scripts/coverage-badge.mjs",
    "audit:ci": "pnpm audit --prod --audit-level=high",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "Michael Scherding",
  "repository": {
    "type": "git",
    "url": "https://github.com/mchl-schrdng/packmind.git"
  },
  "homepage": "https://github.com/mchl-schrdng/packmind",
  "bugs": {
    "url": "https://github.com/mchl-schrdng/packmind/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "ai",
    "context",
    "tokens",
    "cost",
    "memory",
    "developer-tools"
  ],
  "files": [
    "dist/",
    "src/templates/",
    "LICENSE",
    "README.md"
  ]
}
